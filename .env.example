# MongoDB
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/debales-ai?retryWrites=true&w=majority

# Auth (any random secret string, 32+ chars)
AUTH_SECRET=your-super-secret-key-change-this-in-production

# AI - Get free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: OpenRouter fallback (https://openrouter.ai)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# App URL (change in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
